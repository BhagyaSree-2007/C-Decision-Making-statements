/*Write a C program to find the roots of a quadratic equation*/
#include<stdio.h>
#include<math.h>
int main()
{
        float a,b,c,B,d,r,R1,R2;
        printf("Enter values of a,b,c in the equation:");
        scanf("%f,%f,%f",&a,&b,&c);
        B=pow(b,2);
        d=B-(4*a*c);
        r=pow(d,0.5);
        if (d==0)
        {
                R1=-b/(2*a);
                R2=-b/(2*a);
                printf("The roots are %f,%f\n",R1,R2);
        }
        else if (d>0)
        {
                R1=(-b+r)/(2*a);
                R2=(-b-r)/(2*a);
                printf("The roots are %f,%f\n",R1,R2);
        }
        else
                printf("Roots are imaginary\n");
        return 0;
}
